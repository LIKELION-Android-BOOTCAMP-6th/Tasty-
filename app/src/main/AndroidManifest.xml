<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    package = "com.tasty.android">
    <!--퍼미션 선언-->
    <!--인터넷 권한: SDK를 통해 외부와 통신하기 위해 필요함다 / 예: Firebase, Google Maps SDK, Google Places SDK 등-->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!--위치 권한: 런타임 시 요청해야함다 (Level: Dangerous)-->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!--갤러리(사진) 권한: 런타임 시 요청해야함다 (Level: Dangerous) -->
    <!--안드로이드 12이하-->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <!--13이상은 permission이 필요가 없고 Photo Picker를 이용해서 런타임 시 요청을 해야한다네요.-->
    <!--<uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>-->
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/tasty_launcher_ic"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/tasty_launcher_ic_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.Splash"
        android:name=".MyApplication"
        >
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDg3wiqru1hSD1nfs_kXBPzt1EHc057OkI"/>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/AppTheme.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>